@model QuanLyKTX.Models.TienDienNuoc

@{
    ViewData["Title"] = "Xóa Phiếu Thu Tiền Điện Nước";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="card shadow-lg border-danger">
        <div class="card-header bg-danger text-white text-center">
            <h3><i class="fas fa-trash-alt"></i> Xác Nhận Xóa Phiếu Thu</h3>
        </div>
        <div class="card-body">
            <h5 class="text-center text-danger">Bạn có chắc chắn muốn xóa phiếu thu này không?</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-4">Phòng</dt>
                <dd class="col-sm-8">@Model.Phong.TenPhong</dd>

                <dt class="col-sm-4">Ngày Lập Phiếu</dt>
                <dd class="col-sm-8">@Model.NgayTaoPhieu.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-4">Số Điện (kWh)</dt>
                <dd class="col-sm-8">@Model.SoDien</dd>

                <dt class="col-sm-4">Giá Điện (VNĐ/kWh)</dt>
                <dd class="col-sm-8">@Model.GiaDien.ToString("N0")</dd>

                <dt class="col-sm-4">Số Nước (m³)</dt>
                <dd class="col-sm-8">@Model.SoNuoc</dd>

                <dt class="col-sm-4">Giá Nước (VNĐ/m³)</dt>
                <dd class="col-sm-8">@Model.GiaNuoc.ToString("N0")</dd>

                <dt class="col-sm-4 font-weight-bold text-danger">Tổng Tiền (VNĐ)</dt>
                <dd class="col-sm-8 font-weight-bold text-danger">@Model.TongTien.ToString("N0")</dd>
            </dl>
        </div>
        <div class="card-footer text-center">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="MaPhieu" />
                <button type="submit" class="btn btn-danger btn-lg"><i class="fas fa-trash"></i> Xóa</button>
                <a asp-action="Index" class="btn btn-secondary btn-lg"><i class="fas fa-arrow-left"></i> Hủy</a>
            </form>
        </div>
    </div>
</div>