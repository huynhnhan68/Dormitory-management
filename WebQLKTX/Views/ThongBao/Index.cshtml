@model IEnumerable<QuanLyKTX.Models.ThongBao>

@{
    ViewData["Title"] = "Danh Sách Thông Báo";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 rounded border-0" style="background: #fff;">
        <div class="card-header bg-primary text-white text-center rounded-top">
            <h2 class="mb-0">📢 Danh Sách Thông Báo</h2>
        </div>
        <div class="card-body">
            <div class="text-end mb-3">
                <a asp-action="Create" class="btn btn-success px-4 rounded-pill">➕ Tạo Mới</a>
            </div>
            <table class="table table-striped table-hover table-bordered text-center">
                <thead class="bg-light">
                    <tr>
                        <th class="fw-bold">Mã Thông Báo</th>
                        <th class="fw-bold">Tiêu Đề</th>
                        <th class="fw-bold">Nội Dung</th>
                        <th class="fw-bold">Ngày Đăng</th>
                        <th class="fw-bold">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.MaThongBao)</td>
                            <td>@Html.DisplayFor(modelItem => item.TieuDe)</td>
                            <td>@Html.DisplayFor(modelItem => item.NoiDung)</td>
                            <td>@Html.DisplayFor(modelItem => item.NgayDang)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.MaThongBao" class="btn btn-warning btn-sm rounded-pill">✏️ Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.MaThongBao" class="btn btn-info btn-sm rounded-pill">🔍 Chi Tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.MaThongBao" class="btn btn-danger btn-sm rounded-pill">🗑️ Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(to right, #00c6ff, #0072ff);
        font-family: 'Roboto', sans-serif;
    }

    .card-header {
        font-size: 24px;
        letter-spacing: 1px;
    }

    .table th, .table td {
        padding: 15px;
    }

    .table th {
        background-color: #f1f1f1;
        font-weight: 600;
    }

    .btn {
        border-radius: 20px;
        font-size: 14px;
    }

        .btn:hover {
            transform: scale(1.05);
            transition: transform 0.3s ease-in-out;
        }

    .card-body {
        padding: 20px;
    }
</style>
