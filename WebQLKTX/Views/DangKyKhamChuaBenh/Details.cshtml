@model QuanLyKTX.Models.DangKyKhamChuaBenh
@{
    ViewData["Title"] = "Details";
}
<style>
    body {
        background: url('https://i.pinimg.com/736x/0e/1c/45/0e1c45401476310c18f9f4451a0d646a.jpg') no-repeat center center fixed;
        background-size: cover;
    }
</style>

<h1 class="text-info text-center">Chi Tiết Đăng Ký</h1>
<div class="container d-flex justify-content-center">
    <div class="col-md-6 card p-4 shadow-lg bg-light">
        <dl class="row">
            <dt class="col-sm-4">Mã Đăng Ký</dt>
            <dd class="col-sm-8">@Model.MaDangKy</dd>
            <dt class="col-sm-4">Ngày Đăng Ký</dt>
            <dd class="col-sm-8">@Model.NgayDangKy</dd>
            <dt class="col-sm-4">Nội Dung</dt>
            <dd class="col-sm-8">@Model.NoiDung</dd>
            <dt class="col-sm-4">Mã Sinh Viên</dt>
            <dd class="col-sm-8">@Model.MaSV</dd>
        </dl>
        <a asp-action="Index" class="btn btn-secondary">Quay Lại</a>
    </div>
</div>
