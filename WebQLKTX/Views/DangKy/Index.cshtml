@model IEnumerable<QuanLyKTX.Models.Phong>

@{
    ViewData["Title"] = "Danh Sách Phòng";
}

<style>
    body {
        background: url('https://i.pinimg.com/736x/a2/6b/c6/a26bc6a148bded13a6d8b0e1d01893f8.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Arial', sans-serif;
    }

    .container {
        background: rgba(255, 228, 181, 0.9);
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.2);
        max-width: 900px;
        margin: 30px auto;
    }

    h2 {
        text-align: center;
        color: #b22222;
        font-size: 1.6em;
    }

    .table {
        background: rgba(255, 250, 240, 0.9);
        border-radius: 10px;
        overflow: hidden;
        font-size: 0.95em;
        width: 100%;
    }

        .table th, .table td {
            padding: 10px;
            text-align: center;
        }

        .table th {
            background-color: #d2691e;
            color: white;
            font-size: 1em;
        }

    .btn {
        font-size: 0.8em;
        padding: 4px 10px;
        border-radius: 4px;
    }

    .btn-primary {
        background-color: #ff8c00;
        border-color: #ff8c00;
    }

        .btn-primary:hover {
            background-color: #e07b00;
        }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

        .btn-success:hover {
            background-color: #218838;
        }

    .btn-danger {
        background-color: #dc3545;
        border-color: #dc3545;
    }

        .btn-danger:hover {
            background-color: #c82333;
        }

    .btn-warning {
        background-color: #ffc107;
        border-color: #ffc107;
    }

        .btn-warning:hover {
            background-color: #e0a800;
        }

    .action-links {
        display: flex;
        justify-content: center;
        gap: 5px;
    }
</style>

<div class="container">
    <h2>Danh Sách Phòng</h2>
    <p class="text-center">
        <a asp-action="Create" class="btn btn-success">Thêm Phòng</a>
    </p>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Mã Phòng</th>
                <th>Tên Phòng</th>
                <th>Loại Phòng</th>
                <th>Số Lượng Tối Đa</th>
                <th>Số Lượng Hiện Tại</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaPhong</td>
                    <td>@item.TenPhong</td>
                    <td>@item.LoaiPhong</td>
                    <td>@item.SoLuongToiDa</td>
                    <td>@item.SoLuongHienTai</td>
                    <td class="action-links">
                        <a asp-action="Edit" asp-route-id="@item.MaPhong" class="btn btn-warning">Chỉnh Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.MaPhong" class="btn btn-primary">Chi Tiết</a>
                        <a asp-action="Delete" asp-route-id="@item.MaPhong" class="btn btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>