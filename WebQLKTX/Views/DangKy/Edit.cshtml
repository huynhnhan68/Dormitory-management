@model QuanLyKTX.Models.DangKy

@{
    ViewData["Title"] = "Chỉnh Sửa Đăng Ký";
}

<h2>Chỉnh Sửa Đăng Ký</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="MaDangKy" />
    <div class="form-group">
        <label asp-for="NgayDangKy"></label>
        <input asp-for="NgayDangKy" class="form-control" type="date" />
    </div>
    <div class="form-group">
        <label asp-for="NoiDung"></label>
        <input asp-for="NoiDung" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="MaSV"></label>
        <input asp-for="MaSV" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

