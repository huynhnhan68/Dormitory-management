@model QuanLyKTX.Models.DangKy

@{
    ViewData["Title"] = "Xóa Đăng Ký";
}

<h2>Xóa Đăng Ký</h2>

<h3>Bạn có chắc chắn muốn xóa đăng ký này?</h3>
<div>
    <h4>Đăng Ký</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Mã Đăng Ký:</dt>
        <dd>@Model.MaDangKy</dd>

        <dt>Ngày Đăng Ký:</dt>
        <dd>@Model.NgayDangKy.ToString("dd/MM/yyyy")</dd>

        <dt>Nội Dung:</dt>
        <dd>@Model.NoiDung</dd>

        <dt>Mã Sinh Viên:</dt>
        <dd>@Model.MaSV</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="MaDangKy" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>

