@model QuanLyKTX.Models.Phong

@{
    ViewData["Title"] = "Chỉnh Sửa Phòng";

    if (!User.IsInRole("Admin"))
    {
        Context.Response.Redirect("/Phong/Index");
    }
}

<style>
    body {
        background: url('https://i.pinimg.com/736x/d4/f0/2a/d4f02a8423f0190781597952fcaec314.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Arial', sans-serif;
    }

    .form-container {
        background: rgba(255, 228, 181, 0.95);
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0px 6px 15px rgba(0, 0, 0, 0.3);
        max-width: 650px;
        margin: 60px auto;
        border: 3px solid #d2691e;
        text-align: center;
    }
</style>

<div class="container">
    <div class="form-container">
        <h2>Chỉnh Sửa Phòng</h2>
        <form asp-action="Edit">
            <input type="hidden" asp-for="MaPhong" />

            <div class="form-group">
                <label asp-for="TenPhong"></label>
                <input asp-for="TenPhong" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="LoaiPhong" class="control-label"></label>
                <select asp-for="LoaiPhong" class="form-control" asp-items="@(new SelectList(new List<string> { "Nam", "Nữ" }))"></select>
                <span asp-validation-for="LoaiPhong" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SoLuongToiDa"></label>
                <input asp-for="SoLuongToiDa" class="form-control" />
            </div>

            <div class="form-group">
                <label>Số Lượng Sinh Viên Hiện Tại:</label>
                <input type="text" class="form-control" value="@Model.SinhViens.Count" readonly />
            </div>

            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>
