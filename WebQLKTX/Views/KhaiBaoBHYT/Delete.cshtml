@model QuanLyKTX.Models.KhaiBaoBHYT

@{
    ViewData["Title"] = "Xóa khai báo BHYT";
}
<style>
    body {
        background: url('https://i.pinimg.com/736x/72/84/a5/7284a5a694f99e5a850dde33ff47f941.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Arial', sans-serif;
    }
</style>
<div class="container mt-4">
    <h2 class="text-center text-danger">
        <i class="fas fa-exclamation-triangle"></i> Xóa khai báo BHYT
    </h2>
    <p class="text-center text-muted">Bạn có chắc chắn muốn xóa thông tin này? Hành động này không thể hoàn tác.</p>
    <hr />

    <div class="card shadow-lg border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4 fw-bold text-secondary">
                    <i class="fas fa-hashtag"></i> Mã khai báo:
                </dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.MaKhaiBao)</dd>

                <dt class="col-sm-4 fw-bold text-secondary">
                    <i class="fas fa-id-card"></i> Mã thẻ BHYT:
                </dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.MaTheBHYT)</dd>

                <dt class="col-sm-4 fw-bold text-secondary">
                    <i class="fas fa-calendar-alt"></i> Ngày cấp:
                </dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.NgayCap)</dd>

                <dt class="col-sm-4 fw-bold text-secondary">
                    <i class="fas fa-calendar-times"></i> Ngày hết hạn:
                </dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.NgayHetHan)</dd>

                <dt class="col-sm-4 fw-bold text-secondary">
                    <i class="fas fa-user"></i> Mã sinh viên:
                </dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.MaSV)</dd>
            </dl>
        </div>
    </div>

    <div class="text-center mt-4">
        <form asp-action="Delete">
            <input type="hidden" asp-for="MaKhaiBao" />
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash-alt"></i> Xóa ngay
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
        </form>
    </div>
</div>
