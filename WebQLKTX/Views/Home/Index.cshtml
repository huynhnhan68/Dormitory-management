@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* Đảm bảo ảnh nền full màn hình, không có khoảng trống */
    .full-screen-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: url('/images/ảnh1.png') no-repeat center center;
        background-size: cover;
        z-index: -1;
    }

    /* Nội dung overlay */
    .content-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh; /* Full màn hình */
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        font-size: 3rem;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
    }

    /* Xóa khoảng trống giữa sidebar và nội dung */
    .wrapper, .content {
        margin: 0;
        padding: 0;
        height: 100vh; /* Full chiều cao */
    }
</style>

<!-- Ảnh nền toàn màn hình -->
<div class="full-screen-bg"></div>

