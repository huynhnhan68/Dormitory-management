@model IEnumerable<QuanLyKTX.Models.HoaDonTong>

@{
    ViewData["Title"] = "Danh sách hóa đơn tổng";
}

<h2>@ViewData["Title"]</h2>

<a asp-action="Create" class="btn btn-primary mb-3">➕ Tạo hóa đơn</a>

<table class="table table-bordered table-striped">
    <thead class="thead-dark">
        <tr>
            <th>Mã Hóa Đơn</th>
            <th>Mã Phiếu</th>
            <th>Mã Phòng</th>
            <th>Tiền Phòng</th>
            <th>Tiền Điện Nước</th>
            <th>Tổng Hóa Đơn</th>
            <th>Trạng Thái</th>
            <th>Hành Động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaHoaDon</td>
                <td>@item.MaPhieuTienDienNuoc</td>
                <td>@item.MaPhong</td>
                <td>@item.TienPhong.ToString("N0") VNĐ</td>
                <td>@item.TongTienDienNuoc.ToString("N0") VNĐ</td>
                <td><strong>@item.TongHoaDon.ToString("N0") VNĐ</strong></td>
                <td>
                    @if (item.DaThanhToan)
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Chưa thanh toán</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MaHoaDon" class="btn btn-sm btn-warning">✏️ Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.MaHoaDon" class="btn btn-sm btn-danger">🗑️ Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
